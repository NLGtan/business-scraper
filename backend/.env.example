APP_NAME=Business Discovery and Enrichment API
APP_ENV=development
API_PREFIX=/api
BACKEND_CORS_ORIGINS=http://localhost:3000

GOOGLE_MAPS_API_KEY=your_google_maps_places_api_key
REQUEST_TIMEOUT_SECONDS=20
MAX_RETRY_ATTEMPTS=3
DEFAULT_MAX_RESULTS=20
MAX_ALLOWED_RESULTS=100

# Optional: if configured, /api/export/sheets posts selected records to this webhook URL.
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional: reserved for advanced LLM-based enrichment extensions
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

